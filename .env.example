# Copy to `.env` and adjust. Every setting has a working default: with no .env
# at all, the server runs on SQLite with keyless lexical embeddings.

# --- Embeddings -------------------------------------------------------------
# auto (default) -> openai when OPENAI_API_KEY is set, hash otherwise.
# DOCQA_EMBEDDINGS=auto
# OPENAI_API_KEY=sk-your-key-here
# DOCQA_OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- Vector store ------------------------------------------------------------
# sqlite (default, embedded) | pgvector (production; needs DATABASE_URL)
# DOCQA_STORE=sqlite
# DOCQA_SQLITE_PATH=data/index.db

# Matches docker-compose.yml:
# DATABASE_URL=postgresql://docqa:docqa@localhost:5432/docqa
